{
  "name": "bulwark-plugin-impersonation-notice",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=esm --charset=utf8 --outfile=dist/index.js && node -e \"require('fs').copyFileSync('manifest.json','dist/manifest.json')\"",
    "dev": "esbuild src/index.js --bundle --format=esm --charset=utf8 --outfile=dist/index.js --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
